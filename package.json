{
  "name": "skillforge",
  "version": "0.1.0",
  "description": "Host-neutral CLI for authoring, validating, testing, rendering, and packaging portable coding-agent skills.",
  "type": "module",
  "bin": {
    "skillforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "SKILL.md",
    "templates",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs",
    "smoke": "bash scripts/smoke.sh",
    "validate": "bash scripts/validate.sh",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "release:check": "npm run validate && npm run package:smoke",
    "package:smoke": "bash scripts/package-smoke.sh"
  },
  "keywords": [
    "agents",
    "skills",
    "cli",
    "claude",
    "codex",
    "cursor",
    "openclaw",
    "workflow",
    "prompt-engineering"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillforge.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillforge/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillforge#readme"
}
